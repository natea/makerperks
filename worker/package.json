{
  "name": "makerperks-contribute-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Paste-a-URL perk submission Worker: /extract (URL → schema fields via Claude) and /submit (reviewed record → GitHub PR via the makerperks-bot App).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test src/dedup.test.ts",
    "build": "wrangler deploy --dry-run --outdir dist"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.105.0"
  }
}

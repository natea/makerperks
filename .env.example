# Umami analytics (cookieless, no PII). The website ID is public (it ships in the
# page), so it is safe to keep here. The site defaults to this production ID in code;
# set it empty to disable analytics, or change it per environment.
PUBLIC_UMAMI_WEBSITE_ID=fd170bfe-3e87-4a05-8658-a8b8a19311ca

# Optional: point at a self-hosted Umami instance (defaults to Umami Cloud).
# PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js

# Apollo website tracker — company-level visitor identification (a third-party B2B
# de-anonymization service). UNLIKE Umami this is NOT cookieless and NOT consent-free,
# so it is OFF by default (empty) and absent on dev/forks/PR previews. Set it only in
# the production environment to enable. When set, it is geo-gated + consent-gated in
# the browser (loads freely outside the EU/EEA/UK; inside, only after the visitor
# accepts the on-page prompt) and is disclosed in /privacy and /terms.
# PUBLIC_APOLLO_APP_ID=6a3fc4051bb840001c7b810d

# Paste-a-URL contribute flow (/contribute). Base URL of the deployed contribute
# Worker (see worker/) — the /contribute page calls <base>/extract and <base>/submit.
# Empty = the contribute form shows a "coming soon" disabled state. The Turnstile site
# key is public (it ships in the page); set both in the production build to enable.
# PUBLIC_CONTRIBUTE_API=https://makerperks-contribute.natejaune.workers.dev
# PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# Engagement capture substrate (see engagement-worker/). Base URL of the deployed
# engagement Worker — the site's headless helper (src/lib/engagement.ts) POSTs
# <base>/event and GETs <base>/aggregate. Anonymous + privacy-first: a first-party
# session id is minted only on a deliberate action (never on pageview), and no PII is
# stored. Empty = OFF: no id is ever set, the helper is a no-op, and /privacy keeps its
# unqualified "no accounts / no stored data" claims. Set it in production to enable.
# PUBLIC_ENGAGEMENT_ENDPOINT=https://makerperks-engagement.natejaune.workers.dev

# Minimum favorite count before a perk shows a "saved by N+" popularity figure — the
# anti-marketing threshold. The client passes it to the counts endpoint as `min`, so
# sub-threshold counts are never delivered or shown. Defaults to 10.
# PUBLIC_FAVORITES_COUNT_MIN=10

# Copy to .env and fill in. .env is gitignored — never commit real values.
#
# Two kinds of vars live here:
#   • PUBLIC_*        — read by the Astro build and SHIP in the page (safe to expose).
#   • everything else — local tooling / deploy secrets (logo fetch, wrangler, the
#                       contribute Worker). KEEP SECRET. The Worker's runtime secrets
#                       are set with `wrangler secret put` (see worker/README.md), not
#                       read from this file at build time.

# ── Analytics: Umami (cookieless, no PII) ───────────────────────────────────────────
# The website ID is public (it ships in the page). The site defaults to this production
# ID in code; set it empty to disable analytics, or change it per environment.
PUBLIC_UMAMI_WEBSITE_ID=fd170bfe-3e87-4a05-8658-a8b8a19311ca

# Optional: point at a self-hosted Umami instance (defaults to Umami Cloud).
# PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js

# ── Apollo website tracker — company-level visitor identification ────────────────────
# A third-party B2B de-anonymization service. UNLIKE Umami this is NOT cookieless and
# NOT consent-free, so it is OFF by default (empty) and absent on dev/forks/PR previews.
# Set it only in the production environment to enable. When set, it is geo-gated +
# consent-gated in the browser (loads freely outside the EU/EEA/UK; inside, only after
# the visitor accepts the on-page prompt) and is disclosed in /privacy and /terms.
# PUBLIC_APOLLO_APP_ID=6a3fc4051bb840001c7b810d

# ── Paste-a-URL contribute flow (/contribute) ───────────────────────────────────────
# Base URL of the deployed contribute Worker (see worker/) — the page calls
# <base>/extract and <base>/submit. Empty = the form shows its GitHub-guide fallback.
# The Turnstile SITE key is public (it ships in the page); both are build vars.
# PUBLIC_CONTRIBUTE_API=https://makerperks-contribute.<your-subdomain>.workers.dev
# PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_your_site_key

# ── Local tooling / secrets (NOT read by the site build — keep secret) ───────────────
# logo.dev API token for the provider-logo fetch script.
LOGO_DEV_TOKEN=your_logo_dev_token

# Cloudflare auth for `wrangler` (deploying the Workers). wrangler reads
# CLOUDFLARE_API_TOKEN; WRANGLER_AUTH_TOKEN is kept for legacy/compat.
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
WRANGLER_AUTH_TOKEN=your_cloudflare_api_token

# Contribute Worker secrets — used to set the Worker's runtime secrets via
# `wrangler secret put` (or worker/setup.sh). The Worker, not the site, consumes these.
ANTHROPIC_API_KEY=sk-ant-your-key
TURNSTILE_SECRET_KEY=0x4AAAAAAA_your_secret_key

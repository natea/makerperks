---
import Base from "../layouts/Base.astro";

// Static page; the list is hydrated client-side from the session's saved ids joined
// against /search-index.json. No server data needed (and none leaks).
---

<Base
  title="Saved perks — MakerPerks"
  description="The builder perks you've saved on MakerPerks, kept privately in your browser."
>
  <section class="container favs">
    <header class="favs__head">
      <h1 class="favs__title">Saved perks</h1>
      <p class="favs__sub">
        Kept privately in your browser. No account needed; clearing your browser
        data clears this list.
      </p>
      <span class="favs__count tnum" data-favs-count aria-live="polite"></span>
    </header>

    <div class="favs__empty" data-favs-empty hidden>
      <p class="favs__empty-title">Nothing saved yet</p>
      <p class="favs__empty-body">
        Tap the heart on any perk to keep it here for later.
      </p>
      <a class="favs__browse" href="/#personas">Browse perks</a>
    </div>

    <ul class="favs__list" data-favs-list hidden></ul>
  </section>
</Base>

<script>
  import {
    isEngagementEnabled,
    getFavorites,
    unfavorite,
  } from "../lib/engagement";

  type Entry = {
    path: string;
    title: string;
    provider: string;
    providerLabel: string;
    value: string;
    logo: string | null;
  };

  const HEART =
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21.1 10.55 19.8C5.4 15.16 2 12.08 2 8.25 2 5.42 4.24 3.2 7.05 3.2c1.59 0 3.13.74 4.13 1.92l.82.96.82-.96A5.46 5.46 0 0 1 16.95 3.2C19.76 3.2 22 5.42 22 8.25c0 3.83-3.4 6.91-8.55 11.56L12 21.1Z"/></svg>';

  const listEl = document.querySelector<HTMLUListElement>("[data-favs-list]")!;
  const emptyEl = document.querySelector<HTMLElement>("[data-favs-empty]")!;
  const countEl = document.querySelector<HTMLElement>("[data-favs-count]");

  const setCount = (n: number) => {
    if (countEl) countEl.textContent = n > 0 ? `${n} saved` : "";
    const nav = document.querySelector<HTMLElement>("[data-fav-nav-count]");
    if (nav) nav.textContent = n > 0 ? String(n) : "";
  };

  const showEmpty = () => {
    listEl.hidden = true;
    listEl.removeAttribute("aria-busy");
    emptyEl.hidden = false;
    setCount(0);
  };

  function makeItem(e: Entry): HTMLLIElement {
    const id = e.path.replace(/^\/programs\//, "");
    const li = document.createElement("li");
    li.className = "fav-item";

    const link = document.createElement("a");
    link.className = "fav-item__link";
    link.href = e.path;
    link.setAttribute("aria-label", e.title);
    li.append(link);

    if (e.logo) {
      const img = document.createElement("img");
      img.className = "fav-item__logo";
      img.src = e.logo;
      img.alt = "";
      img.width = 36;
      img.height = 36;
      img.loading = "lazy";
      img.decoding = "async";
      li.append(img);
    } else {
      const mono = document.createElement("span");
      mono.className = "fav-item__logo fav-item__logo--mono";
      mono.setAttribute("aria-hidden", "true");
      mono.textContent = e.provider.charAt(0);
      li.append(mono);
    }

    const body = document.createElement("div");
    body.className = "fav-item__body";
    const prov = document.createElement("span");
    prov.className = "fav-item__provider";
    prov.textContent = e.providerLabel;
    const title = document.createElement("span");
    title.className = "fav-item__title";
    title.textContent = e.title;
    body.append(prov, title);
    li.append(body);

    const value = document.createElement("span");
    value.className = "fav-item__value tnum";
    value.textContent = e.value;
    li.append(value);

    const remove = document.createElement("button");
    remove.type = "button";
    remove.className = "fav-item__remove";
    remove.setAttribute("aria-label", `Remove ${e.title} from saved`);
    remove.innerHTML = HEART;
    remove.addEventListener("click", async () => {
      await unfavorite(id);
      li.remove();
      setCount(listEl.children.length);
      if (!listEl.children.length) showEmpty();
    });
    li.append(remove);

    return li;
  }

  async function render() {
    const favs = isEngagementEnabled() ? getFavorites() : [];
    if (!favs.length) {
      showEmpty();
      return;
    }

    // Skeleton rows while the index loads (count is known instantly).
    emptyEl.hidden = true;
    listEl.hidden = false;
    listEl.setAttribute("aria-busy", "true");
    listEl.replaceChildren(
      ...favs.map(() => {
        const sk = document.createElement("li");
        sk.className = "fav-item fav-item--skeleton";
        sk.setAttribute("aria-hidden", "true");
        return sk;
      }),
    );
    setCount(favs.length);

    let entries: Entry[] = [];
    try {
      const res = await fetch("/search-index.json");
      entries = (await res.json()) as Entry[];
    } catch {
      /* offline / fetch failure → fall through to empty */
    }
    const byPath = new Map(entries.map((e) => [e.path, e]));
    const items = favs
      .map((id) => byPath.get(`/programs/${id}`))
      .filter((e): e is Entry => Boolean(e));

    listEl.removeAttribute("aria-busy");
    if (!items.length) {
      showEmpty();
      return;
    }
    listEl.replaceChildren(...items.map(makeItem));
    setCount(items.length);
  }

  render();
</script>

<style>
  .favs {
    padding-block: clamp(2rem, 1.4rem + 3vw, 3.5rem);
  }
  .favs__head {
    margin-bottom: 1.6rem;
  }
  .favs__title {
    font-size: var(--fs-display);
  }
  .favs__sub {
    margin: 0.5rem 0 0;
    color: var(--ink-muted);
    max-width: var(--measure);
  }
  .favs__count {
    display: inline-block;
    margin-top: 0.6rem;
    font-size: var(--fs-sm);
    color: var(--ink-muted);
  }
  .favs__count:empty {
    display: none;
  }

  /* Empty state — teaches the heart affordance, never a dead end. */
  .favs__empty {
    border: 1px dashed var(--hairline-strong);
    border-radius: var(--r-lg);
    padding: clamp(2rem, 1.5rem + 3vw, 3.25rem) 1.5rem;
    text-align: center;
    background: var(--surface);
  }
  .favs__empty-title {
    margin: 0;
    font-size: var(--fs-h3);
    font-weight: 640;
    color: var(--ink);
  }
  .favs__empty-body {
    margin: 0.4rem 0 1.1rem;
    color: var(--ink-muted);
  }
  .favs__browse {
    display: inline-block;
    text-decoration: none;
    font-weight: 560;
    color: var(--green-ink);
    border: 1px solid color-mix(in oklch, var(--green) 40%, var(--hairline));
    background: var(--paper);
    padding: 0.5rem 1.1rem;
    border-radius: var(--r-sm);
    transition:
      border-color 0.16s ease,
      background-color 0.16s ease;
  }
  .favs__browse:hover {
    border-color: var(--green);
    background: var(--green-tint);
  }

  .favs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .fav-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
    background: var(--paper);
    transition: border-color 0.16s ease;
  }
  .fav-item:hover {
    border-color: var(--hairline-strong);
  }
  .fav-item:has(.fav-item__link:focus-visible) {
    outline: 2px solid var(--green);
    outline-offset: 2px;
  }
  .fav-item__link {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }
  .fav-item__logo {
    flex: none;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--r-sm);
    border: 1px solid var(--hairline);
    background: var(--paper);
    object-fit: contain;
    padding: 4px;
  }
  .fav-item__logo--mono {
    display: grid;
    place-items: center;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--ink-muted);
    background: var(--surface);
    padding: 0;
  }
  .fav-item__body {
    display: flex;
    flex-direction: column;
    min-width: 0;
    margin-right: auto;
  }
  .fav-item__provider {
    font-size: var(--fs-xs);
    color: var(--ink-muted);
  }
  .fav-item__title {
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .fav-item__value {
    flex: none;
    font-weight: 640;
    color: var(--green-ink);
    font-size: var(--fs-sm);
  }
  .fav-item__remove {
    position: relative;
    z-index: 2;
    flex: none;
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    color: var(--green-ink);
    cursor: pointer;
    transition:
      color 0.16s ease,
      background-color 0.16s ease,
      border-color 0.16s ease;
  }
  .fav-item__remove svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: var(--green);
    stroke: var(--green-deep);
    stroke-width: 1.5;
    stroke-linejoin: round;
  }
  .fav-item__remove:hover {
    color: var(--amber-ink);
    background: var(--surface);
    border-color: var(--hairline);
  }
  .fav-item__remove:hover svg {
    fill: none;
    stroke: var(--amber-ink);
  }

  /* Skeleton row while the index loads. */
  .fav-item--skeleton {
    height: 3.85rem;
    border-style: dashed;
    background: linear-gradient(var(--surface), var(--surface));
  }
  @media (prefers-reduced-motion: no-preference) {
    .fav-item--skeleton {
      animation: fav-skel 1.1s ease-in-out infinite alternate;
    }
  }
  @keyframes fav-skel {
    from {
      opacity: 0.55;
    }
    to {
      opacity: 0.9;
    }
  }

  @media (max-width: 30rem) {
    .fav-item__value {
      display: none;
    }
  }
</style>

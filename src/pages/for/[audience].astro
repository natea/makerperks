---
import Base from "../../layouts/Base.astro";
import ProgramCard from "../../components/ProgramCard.astro";
import { PERSONAS, personaById } from "../../lib/personas";
import {
  getPublishedPrograms,
  forAudience,
  type Audience,
} from "../../lib/programs";
import { getRecordDates } from "../../lib/recordDates";
import { label } from "../../lib/labels";

export async function getStaticPaths() {
  return PERSONAS.map((p) => ({ params: { audience: p.id } }));
}

const { audience } = Astro.params as { audience: Audience };
const persona = personaById(audience);
const all = await getPublishedPrograms();
const programs = forAudience(all, audience);
// Build-derived added/updated dates back the "Newly added" / "Recently updated" sorts.
const dates = getRecordDates(all);

// Gateway first (the highest-leverage starting point), then the rest by value.
const gateway = persona.gateway
  ? programs.find(
      (p) => p.data.provider_slug === persona.gateway && p.data.aggregator,
    )
  : undefined;
const rest = programs.filter((p) => p.id !== gateway?.id);

// Category facets for the filter bar.
const tagCounts = new Map<string, number>();
for (const p of rest)
  for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const tags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([t]) => t);
// Category chips are collapsed to the most common few; the rest live behind a
// "+N more" disclosure so the filter doesn't become a wall (esp. on mobile).
const VISIBLE_FACETS = 10;
const overflowCount = Math.max(0, tags.length - VISIBLE_FACETS);
---

<Base
  title={`Perks for ${persona.label} — MakerPerks`}
  description={`${programs.length} builder perks for ${persona.noun}. ${persona.tagline}`}
>
  <section class="container head">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>{persona.label}</span>
    </nav>
    <h1 class="head__title">Perks for {persona.label.toLowerCase()}</h1>
    <p class="head__lede">{persona.tagline}</p>
    <p class="head__verify">
      <span class="head__verify-label">How you qualify</span>
      {persona.verify}
    </p>

    <ul class="personas-mini" role="list">
      {
        PERSONAS.filter((p) => p.id !== audience).map((p) => (
          <li>
            <a href={`/for/${p.id}`}>{p.label}</a>
          </li>
        ))
      }
    </ul>
  </section>

  {
    gateway && (
      <section class="container gateway">
        <h2 class="gateway__eyebrow">Start here</h2>
        <a
          class="gateway__card"
          href={`/programs/${gateway.data.provider_slug}/${gateway.id.split("/").pop()}`}
        >
          <div>
            <h3 class="gateway__title">{gateway.data.title}</h3>
            <p class="gateway__intro">{gateway.data.intro}</p>
          </div>
          <span class="gateway__cta">View gateway →</span>
        </a>
      </section>
    )
  }

  <section class="container listing">
    <div class="toolbar">
      <label class="search">
        <span class="visually-hidden">Search {persona.label} programs</span>
        <input
          type="search"
          id="q"
          placeholder={`Search ${rest.length} programs…`}
          autocomplete="off"
        />
      </label>
      <div class="tools">
        <label class="sort">
          <span class="sort__label">Sort</span>
          <select id="sort">
            <option value="value">Dollar value</option>
            <option value="az">A–Z</option>
            <option value="added">Newly added</option>
            <option value="updated">Recently updated</option>
          </select>
        </label>
        <div class="view" role="group" aria-label="View">
          <button
            class="view__btn is-active"
            data-view="tiles"
            type="button"
            aria-pressed="true"
            aria-label="Tile view"
            title="Tile view"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 16 16"
              aria-hidden="true"
              fill="currentColor"
            >
              <rect x="1" y="1" width="6" height="6" rx="1.2"></rect>
              <rect x="9" y="1" width="6" height="6" rx="1.2"></rect>
              <rect x="1" y="9" width="6" height="6" rx="1.2"></rect>
              <rect x="9" y="9" width="6" height="6" rx="1.2"></rect>
            </svg>
            <span class="view__label">Tiles</span>
          </button>
          <button
            class="view__btn"
            data-view="list"
            type="button"
            aria-pressed="false"
            aria-label="List view"
            title="List view"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 16 16"
              aria-hidden="true"
              fill="currentColor"
            >
              <rect x="1" y="2" width="14" height="2.4" rx="1.2"></rect>
              <rect x="1" y="6.8" width="14" height="2.4" rx="1.2"></rect>
              <rect x="1" y="11.6" width="14" height="2.4" rx="1.2"></rect>
            </svg>
            <span class="view__label">List</span>
          </button>
        </div>
      </div>
    </div>
    {
      tags.length > 0 && (
        <div
          class="facets"
          role="group"
          aria-label="Filter by category"
          data-collapsed
        >
          <button class="facet is-active" data-tag="all" type="button">
            All
          </button>
          {tags.map((t, i) => (
            <button
              class:list={["facet", { "facet--overflow": i >= VISIBLE_FACETS }]}
              data-tag={t}
              type="button"
            >
              {label(t)}
            </button>
          ))}
          {overflowCount > 0 && (
            <button
              class="facet-toggle"
              id="facet-more"
              type="button"
              aria-expanded="false"
              data-more-label={`+${overflowCount} more`}
            >
              +{overflowCount} more
            </button>
          )}
        </div>
      )
    }

    <p class="count" id="count" aria-live="polite">{rest.length} programs</p>

    <div class="card-grid" id="grid">
      {
        rest.map((program) => (
          <ProgramCard
            program={program}
            filterable
            added={dates.get(program.id)?.added}
            updated={dates.get(program.id)?.updated}
          />
        ))
      }
    </div>
    {/* Apply the saved view before paint to avoid a tile→list flash. */}
    <script is:inline>
      try {
        if (localStorage.getItem("mp-view") === "list")
          document.getElementById("grid").classList.add("is-list");
      } catch (e) {}
    </script>
    <p class="empty" id="empty" hidden>
      No programs match. <button type="button" id="clear">Clear filters</button>
    </p>
  </section>

  <style>
    .head {
      padding-block: clamp(1.75rem, 1.25rem + 2vw, 2.75rem) 1.25rem;
    }
    .crumbs {
      font-size: var(--fs-sm);
      color: var(--ink-muted);
      margin-bottom: 0.75rem;
    }
    .crumbs a {
      color: var(--green-ink);
      text-decoration: none;
    }
    .head__title {
      font-size: var(--fs-display);
    }
    .head__lede {
      margin: 0.75rem 0 1rem;
      font-size: 1.08rem;
      color: var(--ink-muted);
      max-width: var(--measure);
    }
    .head__verify {
      margin: 0;
      font-size: var(--fs-sm);
      color: var(--ink);
    }
    .head__verify-label {
      display: inline-block;
      margin-right: 0.5rem;
      color: var(--ink-muted);
      font-weight: 560;
    }
    .personas-mini {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.5rem;
      margin: 1.25rem 0 0;
      padding: 0;
    }
    .personas-mini a {
      font-size: var(--fs-xs);
      color: var(--ink-muted);
      text-decoration: none;
      border: 1px solid var(--hairline);
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
    }
    .personas-mini a:hover {
      border-color: var(--green);
      color: var(--ink);
    }

    .gateway {
      padding-block: 0.5rem 1rem;
    }
    .gateway__eyebrow {
      font-size: var(--fs-sm);
      color: var(--green-ink);
      font-weight: 600;
      margin-bottom: 0.6rem;
    }
    .gateway__card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      padding: 1.2rem 1.35rem;
      text-decoration: none;
      border: 1px solid color-mix(in oklch, var(--green) 35%, var(--hairline));
      border-radius: var(--r-lg);
      background: linear-gradient(
        to right,
        var(--green-tint),
        var(--paper) 70%
      );
      transition: border-color 0.16s ease;
    }
    .gateway__card:hover {
      border-color: var(--green);
    }
    .gateway__title {
      font-size: 1.2rem;
    }
    .gateway__intro {
      margin: 0.3rem 0 0;
      color: var(--ink-muted);
      font-size: var(--fs-sm);
      max-width: 60ch;
    }
    .gateway__cta {
      color: var(--green-ink);
      font-weight: 580;
      font-size: var(--fs-sm);
      white-space: nowrap;
    }

    .listing {
      padding-block: 1.25rem;
    }
    .toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.85rem;
    }
    .tools {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem 1rem;
      flex-wrap: wrap;
    }
    /* Tile / list view segmented control */
    .view {
      display: inline-flex;
      border: 1px solid var(--hairline-strong);
      border-radius: var(--r-sm);
      overflow: hidden;
    }
    .view__btn {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font: inherit;
      font-size: var(--fs-sm);
      color: var(--ink-muted);
      background: var(--paper);
      border: 0;
      padding: 0.42rem 0.7rem;
      cursor: pointer;
      transition:
        background 0.14s ease,
        color 0.14s ease;
    }
    .view__btn + .view__btn {
      border-left: 1px solid var(--hairline-strong);
    }
    .view__btn:hover {
      color: var(--ink);
    }
    .view__btn.is-active {
      background: var(--surface);
      color: var(--ink);
    }
    .view__btn svg {
      flex: none;
    }
    .view__btn:focus-visible {
      outline: 2px solid var(--green);
      outline-offset: -2px;
    }
    @media (max-width: 30rem) {
      .view__label {
        display: none;
      }
    }
    .search input {
      width: min(22rem, 60vw);
      font: inherit;
      font-size: var(--fs-sm);
      padding: 0.55rem 0.8rem;
      border: 1px solid var(--hairline-strong);
      border-radius: var(--r-sm);
      background: var(--paper);
      color: var(--ink);
    }
    .search input::placeholder {
      color: var(--ink-muted);
    }
    .search input:focus-visible {
      outline: 2px solid var(--green);
      outline-offset: 1px;
      border-color: var(--green);
    }
    .sort {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: var(--fs-sm);
      color: var(--ink-muted);
    }
    .sort__label {
      font-weight: 560;
    }
    .sort select {
      font: inherit;
      font-size: var(--fs-sm);
      color: var(--ink);
      padding: 0.5rem 2rem 0.5rem 0.7rem;
      border: 1px solid var(--hairline-strong);
      border-radius: var(--r-sm);
      background-color: var(--paper);
      /* native-feeling caret, no custom scrollbar / control reinvention */
      background-image:
        linear-gradient(45deg, transparent 50%, var(--ink-muted) 50%),
        linear-gradient(135deg, var(--ink-muted) 50%, transparent 50%);
      background-position:
        right 0.95rem center,
        right 0.65rem center;
      background-size:
        6px 6px,
        6px 6px;
      background-repeat: no-repeat;
      -webkit-appearance: none;
      appearance: none;
      cursor: pointer;
    }
    .sort select:hover {
      border-color: var(--hairline-strong);
      color: var(--ink);
    }
    .sort select:focus-visible {
      outline: 2px solid var(--green);
      outline-offset: 1px;
      border-color: var(--green);
    }
    .facets {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-bottom: 0.85rem;
    }
    .facet {
      font: inherit;
      font-size: var(--fs-xs);
      cursor: pointer;
      padding: 0.3rem 0.7rem;
      border-radius: 999px;
      border: 1px solid var(--hairline-strong);
      background: var(--paper);
      color: var(--ink-muted);
      transition:
        border-color 0.14s ease,
        color 0.14s ease,
        background 0.14s ease;
    }
    .facet:hover {
      color: var(--ink);
    }
    .facet.is-active {
      background: var(--green);
      border-color: var(--green);
      color: white;
    }
    /* Disclosure: hide the long tail until the toggle expands it. */
    .facets[data-collapsed] .facet--overflow {
      display: none;
    }
    .facet-toggle {
      font: inherit;
      font-size: var(--fs-xs);
      font-weight: 560;
      cursor: pointer;
      padding: 0.3rem 0.7rem;
      border-radius: 999px;
      border: 1px dashed var(--hairline-strong);
      background: transparent;
      color: var(--green-ink);
      transition:
        border-color 0.14s ease,
        color 0.14s ease;
    }
    .facet-toggle:hover {
      border-color: var(--green);
    }
    .count {
      margin: 0 0 1rem;
      font-size: var(--fs-sm);
      color: var(--ink-muted);
    }
    .card-grid {
      display: grid;
      gap: 0.9rem;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }

    /* --- List view: reflow each card into an aligned row (tile markup unchanged;
       head/identity are flattened with display:contents and the leaf elements are
       grid-placed). Composes with the same filter/sort/search. --- */
    .card-grid.is-list {
      grid-template-columns: 1fr;
      gap: 0;
      border-top: 1px solid var(--hairline);
    }
    .card-grid.is-list :global(.card:not([hidden])) {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      grid-template-areas:
        "logo title foot"
        "logo intro foot";
      align-items: center;
      column-gap: 0.9rem;
      row-gap: 0.05rem;
      padding: 0.7rem 0.55rem;
      border: 0;
      border-bottom: 1px solid var(--hairline);
      border-radius: 0;
      background: var(--paper);
    }
    .card-grid.is-list :global(.card:hover) {
      transform: none;
      border-color: var(--hairline);
      background: var(--surface);
    }
    .card-grid.is-list :global(.card--gateway) {
      background: var(--green-tint);
    }
    .card-grid.is-list :global(.card__head),
    .card-grid.is-list :global(.card__identity) {
      display: contents;
    }
    .card-grid.is-list :global(.card__logo) {
      grid-area: logo;
      align-self: center;
    }
    .card-grid.is-list :global(.card__provider),
    .card-grid.is-list :global(.card__flags) {
      display: none;
    }
    .card-grid.is-list :global(.card__title) {
      grid-area: title;
      font-size: var(--fs-sm);
      font-weight: 620;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .card-grid.is-list :global(.card__intro) {
      grid-area: intro;
      -webkit-line-clamp: 1;
      font-size: var(--fs-xs);
    }
    .card-grid.is-list :global(.card__foot) {
      grid-area: foot;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.05rem;
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
      min-width: 8.5rem;
    }
    .card-grid.is-list :global(.card__value) {
      font-size: var(--fs-sm);
    }
    @media (max-width: 40rem) {
      .card-grid.is-list :global(.card:not([hidden])) {
        grid-template-areas: "logo title foot";
      }
      .card-grid.is-list :global(.card__intro),
      .card-grid.is-list :global(.card__verified) {
        display: none;
      }
      .card-grid.is-list :global(.card__foot) {
        min-width: 0;
      }
    }
    .empty {
      padding: 2rem 0;
      color: var(--ink-muted);
    }
    .empty button {
      font: inherit;
      color: var(--green-ink);
      background: none;
      border: none;
      cursor: pointer;
      text-decoration: underline;
    }
  </style>

  <script>
    const grid = document.getElementById("grid")!;
    const cards = [...grid.querySelectorAll<HTMLElement>(".card")];
    const facets = [...document.querySelectorAll<HTMLButtonElement>(".facet")];
    const q = document.getElementById("q") as HTMLInputElement;
    const sort = document.getElementById("sort") as HTMLSelectElement;
    const count = document.getElementById("count")!;
    const empty = document.getElementById("empty")!;
    const clear = document.getElementById("clear");
    let activeTag = "all";

    // Sort comparators. Dates are YYYY-MM-DD, so lexical compare is chronological;
    // value is numeric. Newly-added / recently-updated break ties by value then
    // title so the import-date cluster still lands in a meaningful order.
    function compare(a: HTMLElement, b: HTMLElement, mode: string): number {
      const ta = a.dataset.title ?? "";
      const tb = b.dataset.title ?? "";
      const va = Number(a.dataset.value ?? 0);
      const vb = Number(b.dataset.value ?? 0);
      let r = 0;
      if (mode === "az") r = ta.localeCompare(tb);
      else if (mode === "added")
        r = (b.dataset.added ?? "").localeCompare(a.dataset.added ?? "");
      else if (mode === "updated")
        r = (b.dataset.updated ?? "").localeCompare(a.dataset.updated ?? "");
      else r = vb - va;
      return r || vb - va || ta.localeCompare(tb);
    }

    // Reorder the DOM once per sort change; visibility is handled separately so
    // sort composes cleanly with the active filter + search.
    function reorder() {
      const mode = sort.value;
      [...cards]
        .sort((a, b) => compare(a, b, mode))
        .forEach((card) => grid.appendChild(card));
    }

    function apply() {
      const term = q.value.trim().toLowerCase();
      let shown = 0;
      for (const card of cards) {
        const tags = (card.dataset.tags ?? "").split(",");
        const hay = card.dataset.search ?? "";
        const okTag = activeTag === "all" || tags.includes(activeTag);
        const okTerm = !term || hay.includes(term);
        const show = okTag && okTerm;
        card.hidden = !show;
        if (show) shown++;
      }
      count.textContent = `${shown} program${shown === 1 ? "" : "s"}`;
      empty.hidden = shown !== 0;
    }

    facets.forEach((f) =>
      f.addEventListener("click", () => {
        facets.forEach((x) => x.classList.toggle("is-active", x === f));
        activeTag = f.dataset.tag ?? "all";
        apply();
      }),
    );
    q.addEventListener("input", apply);
    sort.addEventListener("change", reorder);

    // "+N more" disclosure: expand/collapse the long tail of category chips.
    const facetGroup = document.querySelector<HTMLElement>(".facets");
    const moreBtn = document.getElementById("facet-more");
    moreBtn?.addEventListener("click", () => {
      const collapsed = facetGroup!.toggleAttribute("data-collapsed");
      moreBtn.setAttribute("aria-expanded", String(!collapsed));
      moreBtn.textContent = collapsed
        ? (moreBtn.dataset.moreLabel ?? "More")
        : "Show fewer";
    });

    clear?.addEventListener("click", () => {
      q.value = "";
      activeTag = "all";
      facets.forEach((x) =>
        x.classList.toggle("is-active", x.dataset.tag === "all"),
      );
      apply();
    });

    // Tile / list view toggle. Switching only swaps the grid mode class, so the
    // filter/sort/search above (which operate on the same items) are untouched.
    // The choice persists; the inline head script already applied it pre-paint.
    const viewBtns = [
      ...document.querySelectorAll<HTMLButtonElement>(".view__btn"),
    ];
    function setView(view: string) {
      grid.classList.toggle("is-list", view === "list");
      viewBtns.forEach((b) => {
        const on = b.dataset.view === view;
        b.classList.toggle("is-active", on);
        b.setAttribute("aria-pressed", String(on));
      });
      try {
        localStorage.setItem("mp-view", view);
      } catch {}
    }
    // Sync button state to whatever the pre-paint script set.
    setView(grid.classList.contains("is-list") ? "list" : "tiles");
    viewBtns.forEach((b) =>
      b.addEventListener("click", () => setView(b.dataset.view ?? "tiles")),
    );
  </script>
</Base>

---
import Base from "../layouts/Base.astro";
import ProgramCard from "../components/ProgramCard.astro";
import { PERSONAS } from "../lib/personas";
import {
  getPublishedPrograms,
  forAudience,
  byValueDesc,
} from "../lib/programs";

const programs = await getPublishedPrograms();
const total = programs.length;
const top = [...programs].sort(byValueDesc).slice(0, 6);

const personaCounts = Object.fromEntries(
  PERSONAS.map((p) => [p.id, forAudience(programs, p.id).length]),
);
---

<Base title="MakerPerks — builder perks worth claiming">
  <section class="hero">
    <div class="container">
      <p class="hero__kicker">{total} programs · no ads · no affiliate links</p>
      <h1 class="hero__title">
        The free credits and tools you're<br /> already eligible for.
      </h1>
      <p class="hero__lede">
        Hundreds of thousands of dollars in cloud, AI, and developer perks are
        sitting unclaimed across viral posts and dead lists. MakerPerks puts
        them in one place, sorted by what you'll actually get. Start with who
        you are.
      </p>
      <a href="#personas" class="btn btn--primary">Find my perks ↓</a>
    </div>
  </section>

  <section id="personas" class="personas">
    <div class="container">
      <h2 class="section__title">Who are you?</h2>
      <p class="section__sub">
        Pick the hat you're wearing. Many programs serve more than one — you'll
        see every perk you qualify for.
      </p>
      <ul class="persona-grid" role="list">
        {
          PERSONAS.map((p) => (
            <li>
              <a class="persona" href={`/for/${p.id}`}>
                <div class="persona__top">
                  <span class="persona__label">{p.label}</span>
                  <span class="persona__count tnum">{personaCounts[p.id]}</span>
                </div>
                <p class="persona__tagline">{p.tagline}</p>
                <span class="persona__verify">{p.verify}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="top">
    <div class="container">
      <div class="top__head">
        <h2 class="section__title">Highest value, right now</h2>
        <p class="section__sub">The biggest programs across every audience.</p>
      </div>
      <div class="card-grid">
        {top.map((program) => <ProgramCard program={program} />)}
      </div>
    </div>
  </section>

  <style>
    .hero {
      padding-block: clamp(3rem, 2rem + 6vw, 6rem)
        clamp(2rem, 1.5rem + 3vw, 3.5rem);
      border-bottom: 1px solid var(--hairline);
    }
    .hero__kicker {
      margin: 0 0 1rem;
      font-size: var(--fs-sm);
      color: var(--green-ink);
      font-weight: 560;
    }
    .hero__title {
      font-size: var(--fs-display);
      max-width: 16ch;
    }
    .hero__lede {
      margin: 1.1rem 0 1.6rem;
      max-width: 56ch;
      font-size: 1.08rem;
      color: var(--ink-muted);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-weight: 580;
      font-size: var(--fs-sm);
      padding: 0.7rem 1.2rem;
      border-radius: var(--r-sm);
      text-decoration: none;
      transition:
        background 0.16s ease,
        transform 0.16s ease;
    }
    .btn--primary {
      background: var(--green);
      color: white;
    }
    .btn--primary:hover {
      background: var(--green-deep);
      transform: translateY(-1px);
    }

    .personas,
    .top {
      padding-block: clamp(2.5rem, 2rem + 3vw, 4rem);
    }
    .section__title {
      font-size: var(--fs-h2);
    }
    .section__sub {
      margin: 0.5rem 0 0;
      color: var(--ink-muted);
      max-width: var(--measure);
    }

    .persona-grid {
      list-style: none;
      margin: 1.75rem 0 0;
      padding: 0;
      display: grid;
      gap: 0.9rem;
      grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
    }
    .persona {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      height: 100%;
      padding: 1.15rem 1.2rem 1.2rem;
      text-decoration: none;
      background: var(--paper);
      border: 1px solid var(--hairline);
      border-radius: var(--r-md);
      transition:
        border-color 0.16s ease,
        transform 0.16s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .persona:hover {
      border-color: var(--green);
      transform: translateY(-2px);
    }
    .persona__top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .persona__label {
      font-size: 1.15rem;
      font-weight: 640;
      letter-spacing: -0.01em;
    }
    .persona__count {
      font-size: var(--fs-sm);
      font-weight: 600;
      color: var(--green-ink);
      background: var(--green-tint);
      padding: 0.05rem 0.5rem;
      border-radius: 999px;
    }
    .persona__tagline {
      margin: 0;
      color: var(--ink);
      font-size: var(--fs-sm);
      line-height: 1.5;
    }
    .persona__verify {
      margin-top: auto;
      padding-top: 0.4rem;
      font-size: var(--fs-xs);
      color: var(--ink-muted);
    }

    .top__head {
      margin-bottom: 1.5rem;
    }
    .card-grid {
      display: grid;
      gap: 0.9rem;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }
  </style>
</Base>

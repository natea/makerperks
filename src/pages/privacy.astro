---
// NOTE: Starter content. This is a good-faith starting point, not legal advice —
// the owner / counsel should review and finalize before relying on it.
import Base from "../layouts/Base.astro";

const updated = "2026-06-27";

// Mirrors Base.astro: when the Apollo visitor-identification service is enabled, the
// policy must disclose it and stop claiming "no marketing trackers / no third-party
// sharing" without qualification. Off (the default) keeps the original strong claims.
const APOLLO_ENABLED = Boolean(import.meta.env.PUBLIC_APOLLO_APP_ID);

// When the engagement substrate is enabled, saving a perk stores a first-party
// functional id + your saved targets (no personal data). Off (default) keeps the
// "no accounts / no stored data" claims below unqualified.
const ENGAGEMENT_ENABLED = Boolean(import.meta.env.PUBLIC_ENGAGEMENT_ENDPOINT);
---

<Base
  title="Privacy Policy — MakerPerks"
  description="How MakerPerks handles data: cookieless analytics, no personal data, no ads or affiliate tracking."
>
  <article class="container legal">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Privacy Policy</span>
    </nav>
    <h1 class="legal__title">Privacy Policy</h1>
    <p class="legal__updated tnum">Last updated {updated}</p>

    <section class="prose">
      <p>
        MakerPerks is a static, browseable directory of builder perks. We aim to
        collect as little as possible, and never to sell or share your data.
      </p>

      <h2>What we collect</h2>
      <p>
        We use <a href="https://umami.is/" rel="noopener" target="_blank"
          >Umami</a
        >, a privacy-friendly analytics tool, to understand which pages and
        personas are useful. Umami is <strong>cookieless</strong> and does not collect
        personal data or build advertising profiles. It records aggregate, anonymized
        signals such as page views, referrers, and approximate region — never your
        name, email, or a cross-site identifier.
      </p>

      {
        APOLLO_ENABLED && (
          <>
            <h2>Company-level visitor identification</h2>
            <p>
              On some pages we use{" "}
              <a href="https://www.apollo.io/" rel="noopener" target="_blank">
                Apollo
              </a>
              , a third-party service, to identify the <strong>company</strong>{" "}
              associated with a visitor — for example, to understand which
              organizations find MakerPerks useful. This identifies an
              organization,
              <strong> not you as an individual</strong>, and works by sharing
              your request's IP address with Apollo, which reverse-resolves it
              to a company.
            </p>
            <p>
              This is the one exception to the "no third-party sharing" rule
              below, and we treat it carefully. It is{" "}
              <strong>off by default</strong>, and where the law requires prior
              consent (the EU, EEA, and UK) it does not load until you accept
              the prompt shown at the bottom of the page; declining keeps it
              off. Our cookieless page analytics (above) is separate and runs
              regardless. Apollo's handling of the data it receives is governed
              by{" "}
              <a
                href="https://www.apollo.io/privacy-policy"
                rel="noopener"
                target="_blank"
              >
                Apollo's privacy policy
              </a>
              .
            </p>
          </>
        )
      }

      {
        ENGAGEMENT_ENABLED && (
          <>
            <h2>Saving perks</h2>
            <p>
              If you save a perk (add it to favorites), we store a{" "}
              <strong>first-party functional identifier</strong> in your
              browser's local storage and record which perks you saved on our
              own servers, so your list is there when you come back. This
              identifier is created{" "}
              <strong>only when you take that action</strong> — not from
              browsing — and is <strong>random and anonymous</strong>: it is not
              your name or email, is never shared with a third party, and is not
              a cross-site advertising cookie. Clearing your browser storage
              forgets it. Our cookieless page analytics (above) is separate and
              unaffected.
            </p>
          </>
        )
      }

      <h2>What we do not do</h2>
      <ul>
        {
          APOLLO_ENABLED ? (
            <li>
              No advertising or retargeting trackers, and no marketing trackers
              beyond the company-level visitor identification described above.
            </li>
          ) : (
            <li>No advertising or marketing trackers.</li>
          )
        }
        <li>No affiliate links or referral codes.</li>
        {
          ENGAGEMENT_ENABLED ? (
            <li>
              No accounts or sign-ups. The only data tied to you is the
              anonymous saved-perks list described above — no personal
              information.
            </li>
          ) : (
            <li>No accounts, sign-ups, or stored personal information.</li>
          )
        }
        {
          APOLLO_ENABLED ? (
            <li>
              No selling of your data, and no sharing with third parties except
              the company-level visitor identification described above.
            </li>
          ) : (
            <li>No selling or sharing of data with third parties.</li>
          )
        }
      </ul>

      <h2>Links to other sites</h2>
      <p>
        Program listings link to third-party provider websites. Once you follow
        a link, that provider's own privacy policy applies; we have no control
        over their practices.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about this policy? Reach us through the
        <a href="/#personas">site</a> or the project's GitHub repository.
      </p>
    </section>
  </article>

  <style>
    .legal {
      padding-block: clamp(1.5rem, 1rem + 2vw, 2.5rem) 3rem;
    }
    .crumbs {
      font-size: var(--fs-sm);
      color: var(--ink-muted);
      margin-bottom: 1.25rem;
    }
    .crumbs a {
      color: var(--green-ink);
      text-decoration: none;
    }
    .legal__title {
      font-size: var(--fs-display);
    }
    .legal__updated {
      margin: 0.5rem 0 0;
      font-size: var(--fs-sm);
      color: var(--ink-muted);
    }
    .prose {
      margin-top: 2rem;
      max-width: var(--measure);
      display: grid;
      gap: 0.9rem;
    }
    .prose h2 {
      font-size: var(--fs-h2);
      margin-top: 1rem;
    }
    .prose a {
      color: var(--green-ink);
    }
    .prose ul {
      margin: 0;
      padding-left: 1.1rem;
      display: grid;
      gap: 0.3rem;
    }
  </style>
</Base>

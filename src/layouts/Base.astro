---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  jsonLd?: unknown;
}
const {
  title,
  description = "A browseable, agent-friendly directory of builder perks — free credits, discounts, and programs for startups, students, OSS maintainers, indie devs, and non-profits.",
  jsonLd,
} = Astro.props;
const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />
    <link
      rel="alternate"
      type="application/json"
      href="/perks.json"
      title="perks.json"
    />
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <header class="site-head">
      <div class="container site-head__inner">
        <a href="/" class="brand" aria-label="MakerPerks home">
          <span class="brand__mark" aria-hidden="true"></span>
          <span class="brand__name">MakerPerks</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/#personas">Browse</a>
          <a href="/llms.txt">For agents</a>
          <a
            href="https://github.com/makerperks"
            rel="noopener"
            class="site-nav__cta">Contribute</a
          >
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="container site-foot__inner">
        <p>
          <strong>MakerPerks</strong> — builder perks worth claiming. No ads, no affiliate
          links.
        </p>
        <p class="site-foot__meta">
          Data via <a href="/perks.json">perks.json</a> ·
          <a href="/llms.txt">llms.txt</a> · Always confirm the current offer on the
          provider's page. © {year}
        </p>
      </div>
    </footer>

    <style>
      .skip {
        position: absolute;
        left: 1rem;
        top: -3rem;
        background: var(--ink);
        color: var(--paper);
        padding: 0.5rem 0.9rem;
        border-radius: var(--r-sm);
        transition: top 0.15s ease;
        z-index: var(--z-dropdown);
      }
      .skip:focus {
        top: 1rem;
      }

      .site-head {
        position: sticky;
        top: 0;
        z-index: var(--z-sticky);
        background: color-mix(in oklch, var(--paper) 88%, transparent);
        backdrop-filter: saturate(1.4) blur(8px);
        border-bottom: 1px solid var(--hairline);
      }
      .site-head__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        height: 3.75rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
        font-weight: 680;
        letter-spacing: -0.02em;
      }
      .brand__mark {
        width: 1.15rem;
        height: 1.15rem;
        border-radius: 5px;
        background: var(--green);
        box-shadow: inset 0 0 0 3px color-mix(in oklch, var(--green) 60%, white);
      }
      .site-nav {
        display: flex;
        align-items: center;
        gap: clamp(0.75rem, 2vw, 1.5rem);
        font-size: var(--fs-sm);
      }
      .site-nav a {
        text-decoration: none;
        color: var(--ink-muted);
        transition: color 0.15s ease;
      }
      .site-nav a:hover {
        color: var(--ink);
      }
      .site-nav__cta {
        color: var(--ink) !important;
        border: 1px solid var(--hairline-strong);
        padding: 0.4rem 0.85rem;
        border-radius: var(--r-sm);
      }
      .site-nav__cta:hover {
        border-color: var(--green);
      }
      @media (max-width: 36rem) {
        .site-nav a:not(.site-nav__cta) {
          display: none;
        }
      }

      .site-foot {
        margin-top: 4rem;
        border-top: 1px solid var(--hairline);
        background: var(--surface);
      }
      .site-foot__inner {
        padding-block: 2rem;
        display: grid;
        gap: 0.35rem;
      }
      .site-foot__meta {
        color: var(--ink-muted);
        font-size: var(--fs-sm);
      }
      .site-foot a {
        color: var(--green-ink);
        text-decoration: none;
      }
      .site-foot a:hover {
        text-decoration: underline;
      }
    </style>
  </body>
</html>

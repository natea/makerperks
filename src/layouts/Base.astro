---
import "../styles/global.css";
import SearchPalette from "../components/SearchPalette.astro";
import ApolloConsent from "../components/ApolloConsent.astro";
import ContributeBanner from "../components/ContributeBanner.astro";
import FavoritesController from "../components/FavoritesController.astro";

interface Props {
  title: string;
  description?: string;
  jsonLd?: unknown;
  /** Share image path (defaults to the branded card); resolved absolute below. */
  image?: string;
  /** Canonical path (defaults to the current URL). */
  canonical?: string;
}
const {
  title,
  description = "A browseable, agent-friendly directory of builder perks — free credits, discounts, and programs for startups, students, OSS maintainers, indie devs, and non-profits.",
  jsonLd,
  image = "/og-default.png",
  canonical,
} = Astro.props;
const year = 2026;

// Social scrapers need absolute URLs. Resolve image + canonical against the site.
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, Astro.site).href;
const imageUrl = new URL(image, Astro.site).href;

// Umami analytics (cookieless, no PII, no consent banner). Defaults to the production
// website ID. Override per environment with PUBLIC_UMAMI_WEBSITE_ID (set it empty to
// disable), and point at a self-hosted instance with PUBLIC_UMAMI_SRC.
const UMAMI_ID =
  import.meta.env.PUBLIC_UMAMI_WEBSITE_ID ??
  "fd170bfe-3e87-4a05-8658-a8b8a19311ca";
const UMAMI_SRC =
  import.meta.env.PUBLIC_UMAMI_SRC ?? "https://cloud.umami.is/script.js";

// Apollo website tracker — company-level visitor identification (NOT cookieless,
// NOT consent-free; this is a third-party B2B de-anonymization service). Off by
// default so dev/forks/PR previews never load it; set PUBLIC_APOLLO_APP_ID in the
// production environment to enable (the provided app id is documented in .env.example).
// When enabled, it is geo-gated + consent-gated client-side (see the script below):
// loaded freely outside consent-required jurisdictions, and only after explicit
// consent within the EU/EEA/UK. Disclosed in /privacy and /terms.
const APOLLO_APP_ID = import.meta.env.PUBLIC_APOLLO_APP_ID ?? "";

// Favorites surface is build-time gated on the engagement endpoint being configured.
const ENGAGEMENT_ON = Boolean(import.meta.env.PUBLIC_ENGAGEMENT_ENDPOINT);

// Feedback form (Google Forms) — the MakerPerks Feedback form.
const FEEDBACK_FORM_URL =
  "https://docs.google.com/forms/d/e/1FAIpQLSdA8YgP3sRoVlak0TKQGFUe13TkMgIywU4KSFbGwfK0wfg0NQ/viewform";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph + Twitter Card — rich link previews */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MakerPerks" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />
    <link
      rel="alternate"
      type="application/json"
      href="/perks.json"
      title="perks.json"
    />
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
    {UMAMI_ID && <script defer src={UMAMI_SRC} data-website-id={UMAMI_ID} />}
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <ContributeBanner />
    <header class="site-head">
      <div class="container site-head__inner">
        <a href="/" class="brand" aria-label="MakerPerks home">
          <span class="brand__mark" aria-hidden="true"></span>
          <span class="brand__name">MakerPerks</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <button
            type="button"
            class="site-search"
            data-search-open
            aria-label="Search programs"
            aria-keyshortcuts="Meta+K Control+K"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <span class="site-search__label">Search</span>
            <kbd class="site-search__kbd" aria-hidden="true">⌘K</kbd>
          </button>
          <a href="/#personas">Browse</a>
          {
            ENGAGEMENT_ON && (
              <a href="/favorites" class="site-nav__saved">
                <svg
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 21.1 10.55 19.8C5.4 15.16 2 12.08 2 8.25 2 5.42 4.24 3.2 7.05 3.2c1.59 0 3.13.74 4.13 1.92l.82.96.82-.96A5.46 5.46 0 0 1 16.95 3.2C19.76 3.2 22 5.42 22 8.25c0 3.83-3.4 6.91-8.55 11.56L12 21.1Z" />
                </svg>
                Saved
                <span class="site-nav__saved-count tnum" data-fav-nav-count />
              </a>
            )
          }
          <a href="/agents">For agents</a>
          <a href="/contribute" class="site-nav__cta">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Contribute</a
          >
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <SearchPalette />

    {ENGAGEMENT_ON && <FavoritesController />}

    <footer class="site-foot">
      <div class="container site-foot__inner">
        <p class="site-foot__tagline">
          <strong>MakerPerks</strong> &mdash; builder perks worth claiming. No ads,
          no affiliate links.
        </p>
        <nav class="site-foot__links" aria-label="Footer">
          <a href={FEEDBACK_FORM_URL} target="_blank" rel="noopener">Feedback</a
          >
          <a href="/agents">For agents</a>
          {ENGAGEMENT_ON && <a href="/favorites">Saved</a>}
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Use</a>
          <a href="/perks.json">perks.json</a>
          <a href="/llms.txt">llms.txt</a>
          {
            /* Withdraw or revisit analytics consent — only when Apollo is enabled.
               Handled by ApolloConsent.astro's script via [data-consent-reopen]. */
            APOLLO_APP_ID && (
              <button
                type="button"
                class="site-foot__manage"
                data-consent-reopen
              >
                Tracking settings
              </button>
            )
          }
        </nav>
        <p class="site-foot__meta">
          Always confirm the current offer on the provider's page. &copy; {year}
          Jazkarta, Inc.
        </p>
      </div>
    </footer>

    {
      /* Apollo company-level visitor identification (config-gated). Self-contained:
         renders nothing unless PUBLIC_APOLLO_APP_ID is set, so it's absent on
         dev/forks/PR previews. Geo- + consent-gated inside the component. Cookieless
         Umami above is unaffected and needs no consent. */
      APOLLO_APP_ID && <ApolloConsent appId={APOLLO_APP_ID} />
    }

    <style>
      .skip {
        position: absolute;
        left: 1rem;
        top: -3rem;
        background: var(--ink);
        color: var(--paper);
        padding: 0.5rem 0.9rem;
        border-radius: var(--r-sm);
        transition: top 0.15s ease;
        z-index: var(--z-dropdown);
      }
      .skip:focus {
        top: 1rem;
      }

      .site-head {
        position: sticky;
        top: 0;
        z-index: var(--z-sticky);
        background: color-mix(in oklch, var(--paper) 88%, transparent);
        backdrop-filter: saturate(1.4) blur(8px);
        border-bottom: 1px solid var(--hairline);
      }
      .site-head__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        height: 3.75rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
        font-weight: 680;
        letter-spacing: -0.02em;
      }
      .brand__mark {
        width: 1.15rem;
        height: 1.15rem;
        border-radius: 5px;
        background: var(--green);
        box-shadow: inset 0 0 0 3px color-mix(in oklch, var(--green) 60%, white);
      }
      .site-nav {
        display: flex;
        align-items: center;
        gap: clamp(0.75rem, 2vw, 1.5rem);
        font-size: var(--fs-sm);
      }
      .site-search {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font: inherit;
        font-size: var(--fs-sm);
        color: var(--ink-muted);
        background: var(--paper);
        border: 1px solid var(--hairline-strong);
        border-radius: var(--r-sm);
        padding: 0.4rem 0.6rem;
        cursor: pointer;
        transition:
          border-color 0.15s ease,
          color 0.15s ease;
      }
      .site-search:hover {
        border-color: var(--green);
        color: var(--ink);
      }
      .site-search svg {
        flex: none;
      }
      .site-search__kbd {
        font-family: inherit;
        font-size: var(--fs-xs);
        color: var(--ink-muted);
        border: 1px solid var(--hairline);
        border-radius: 4px;
        padding: 0 0.3rem;
      }
      @media (max-width: 36rem) {
        .site-search__label,
        .site-search__kbd {
          display: none;
        }
        .site-search {
          padding: 0.4rem;
        }
      }
      .site-nav a {
        text-decoration: none;
        color: var(--ink-muted);
        transition: color 0.15s ease;
      }
      .site-nav a:hover {
        color: var(--ink);
      }
      .site-nav__cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--ink) !important;
        border: 1px solid var(--hairline-strong);
        padding: 0.4rem 0.85rem;
        border-radius: var(--r-sm);
      }
      .site-nav__cta svg {
        flex: none;
      }
      .site-nav__cta:hover {
        border-color: var(--green);
      }
      .site-nav__saved {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }
      .site-nav__saved svg {
        flex: none;
      }
      /* The count badge only renders once JS fills it (empty = no chrome). */
      .site-nav__saved-count:not(:empty) {
        min-width: 1.1rem;
        padding: 0 0.32rem;
        border-radius: 999px;
        background: var(--green-tint);
        color: var(--green-ink);
        font-size: var(--fs-xs);
        font-weight: 600;
        line-height: 1.35;
        text-align: center;
      }
      @media (max-width: 36rem) {
        .site-nav a:not(.site-nav__cta) {
          display: none;
        }
      }

      .site-foot {
        margin-top: 4rem;
        border-top: 1px solid var(--hairline);
        background: var(--surface);
      }
      .site-foot__inner {
        padding-block: 2rem;
        display: grid;
        gap: 0.55rem;
      }
      .site-foot__tagline {
        margin: 0;
        font-size: var(--fs-sm);
        color: var(--ink-muted);
      }
      .site-foot__links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem 0.9rem;
        font-size: var(--fs-xs);
      }
      .site-foot__meta {
        margin: 0;
        color: var(--ink-muted);
        font-size: var(--fs-xs);
      }
      .site-foot a {
        color: var(--green-ink);
        text-decoration: none;
      }
      .site-foot a:hover {
        text-decoration: underline;
      }
      /* "Tracking settings" — a button (it performs an action) styled to read as a
         footer link so it sits inline with the others. */
      .site-foot__manage {
        font: inherit;
        font-size: var(--fs-xs);
        color: var(--green-ink);
        background: none;
        border: 0;
        padding: 0;
        cursor: pointer;
      }
      .site-foot__manage:hover {
        text-decoration: underline;
      }
    </style>
  </body>
</html>
